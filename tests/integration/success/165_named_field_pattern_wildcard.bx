struct Point {
    x: int,
    y: int
}

var p1 := Point { x: 3, y: 7 }
var result1 := match p1 {
    { x: _, y: py } -> py
}
println(result1)

var p2 := Point { x: 0, y: 9 }
var result2 := match p2 {
    { x: 0, y: _ } -> 100
    { x: _, y: _ } -> -1
}
println(result2)

var p3 := Point { x: 4, y: 9 }
var result3 := match p3 {
    { x: 0, y: _ } -> 100
    { x: _, y: _ } -> -1
}
println(result3)
