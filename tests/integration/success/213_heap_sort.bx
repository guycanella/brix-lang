// Heap sort via MinHeap: 10 shuffled values (> Vector's initial cap of 8,
// so this also exercises the growth path through brix_vector_push inside
// brix_heap_push) — pop must produce them in ascending order.
var h := MinHeap<int>()
h.push(7)
h.push(2)
h.push(9)
h.push(1)
h.push(5)
h.push(8)
h.push(0)
h.push(6)
h.push(4)
h.push(3)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
println(h.pop() ?: -1)
