// Test: array slicing with closed ranges (v1.7 Group C)
var nums := [10, 20, 30, 40, 50]

var sub := nums[1..3]
println(sub.cols)
println(sub[0])
println(sub[1])
println(sub[2])

var sub2 := nums[1..<4]
println(sub2.cols)
println(sub2[0])
println(sub2[1])
println(sub2[2])

var fnums := [1.5, 2.5, 3.5, 4.5]

var fsub := fnums[1..3]
println(fsub.cols)
println(fsub[0])
println(fsub[2])

var fsub2 := fnums[1..<3]
println(fsub2.cols)
println(fsub2[0])
println(fsub2[1])
