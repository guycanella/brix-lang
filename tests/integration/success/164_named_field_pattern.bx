struct Point {
    x: int,
    y: int
}

var p1 := Point { x: 3, y: 0 }
var result1 := match p1 {
    { x: px, y: 0 } -> px
    { x: 0, y: py } -> py
    { x: px, y: py } -> px + py
    _ -> -1
}
println(result1)

var p2 := Point { x: 0, y: 5 }
