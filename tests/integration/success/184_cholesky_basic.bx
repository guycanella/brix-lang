import math

// Cholesky A = L*L^T for SPD A = [[4,2],[2,3]] -> L = [[2,0],[1,sqrt(2)]].
// The strict upper triangle must be explicitly zeroed (dpotrf leaves garbage).
var A := zeros(2, 2)
A[0][0] := 4.0
A[0][1] := 2.0
A[1][0] := 2.0
A[1][1] := 3.0

var L := math.cholesky(A)

println(L[0][0])   // 2
println(L[1][0])   // 1
println(L[0][1])   // 0  (upper triangle zeroed)
