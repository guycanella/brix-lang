// Test: any and all on IntMatrix
var nums := [1, 2, 3, 4, 5]

var has_even := nums.any((x: int) -> bool { return x % 2 == 0 })
println(has_even)

var all_pos := nums.all((x: int) -> bool { return x > 0 })
println(all_pos)

var all_even := nums.all((x: int) -> bool { return x % 2 == 0 })
println(all_even)

var has_gt_10 := nums.any((x: int) -> bool { return x > 10 })
println(has_gt_10)
