import test

async fn fetch_value() -> int {
    return 42
}

async fn fetch_sum(a: int, b: int) -> int {
    var x := await fetch_value()
    return x + a + b
}

async fn fetch_double(n: int) -> int {
    return n * 2
}

test.describe("Async functions", () -> {
    test.it("resolves simple async value", async () -> {
        var result := await fetch_value()
        test.expect(result).toBe(42)
    })

    test.it("chains awaits correctly", async () -> {
        var result := await fetch_sum(1, 2)
        test.expect(result).toBe(45)
    })

    test.it("resolves with parameters", async () -> {
        var result := await fetch_double(21)
        test.expect(result).toBe(42)
    })
})
