import test

test.describe("Vector<int> (v1.8 Grupo C, Phase 1)", () -> {
    test.it("push then get/len", () -> {
        var v := Vector<int>()
        v.push(10)
        v.push(20)
        v.push(30)
        test.expect(v.len()).toBe(3)
        test.expect(v.get(0)).toBe(10)
        test.expect(v.get(2)).toBe(30)
    })

    test.it("grows past initial capacity (2x growth)", () -> {
        var v := Vector<int>()
        var i := 0
        while i < 20 {
            v.push(i * i)
            i := i + 1
        }
        test.expect(v.len()).toBe(20)
        test.expect(v.get(19)).toBe(361)
        test.expect(v.get(10)).toBe(100)
    })
})

test.describe("Vector<int> set/pop/is_empty/clear (v1.8 Grupo C, Phase 2)", () -> {
    test.it("set overwrites in place", () -> {
        var v := Vector<int>()
        v.push(10)
        v.push(20)
        v.set(1, 99)
        test.expect(v.get(1)).toBe(99)
        test.expect(v.len()).toBe(2)
    })

    test.it("pop returns last element and shrinks", () -> {
        var v := Vector<int>()
        v.push(1)
        v.push(2)
        var x := v.pop()
        test.expect(x ?: -1).toBe(2)
        test.expect(v.len()).toBe(1)
    })

    test.it("pop on empty returns nil", () -> {
        var v := Vector<int>()
        var y := v.pop()
        test.expect(y == nil).toBeTruthy()
    })

    test.it("is_empty reflects contents", () -> {
        var v := Vector<int>()
        test.expect(v.is_empty()).toBe(1)
        v.push(5)
        test.expect(v.is_empty()).toBe(0)
    })

    test.it("clear empties but keeps the vector reusable", () -> {
        var v := Vector<int>()
        v.push(1)
        v.push(2)
        v.push(3)
        v.clear()
        test.expect(v.is_empty()).toBe(1)
        v.push(42)
        test.expect(v.get(0)).toBe(42)
        test.expect(v.len()).toBe(1)
    })
})

test.describe("Vector<float> (v1.8 Grupo C, Phase 3)", () -> {
    test.it("push/get/set with float values", () -> {
        var v := Vector<float>()
        v.push(1.5)
        v.push(2.5)
        v.push(3.5)
        test.expect(v.get(0)).toBeCloseTo(1.5)
        test.expect(v.get(2)).toBeCloseTo(3.5)
        v.set(1, 9.5)
        test.expect(v.get(1)).toBeCloseTo(9.5)
        test.expect(v.len()).toBe(3)
    })

    test.it("pop returns float? and empties to nil", () -> {
        var v := Vector<float>()
        v.push(1.5)
        v.push(2.5)
        var x := v.pop()
        test.expect(x ?: 0.0).toBeCloseTo(2.5)
        test.expect(v.len()).toBe(1)
        var drop := v.pop()
        var y := v.pop()
        test.expect(y == nil).toBeTruthy()
    })

    test.it("grows past initial capacity", () -> {
        var v := Vector<float>()
        var i := 0
        while i < 12 {
            v.push(i * 1.0)
            i := i + 1
        }
        test.expect(v.len()).toBe(12)
        test.expect(v.get(11)).toBeCloseTo(11.0)
    })
})
