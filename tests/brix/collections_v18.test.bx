import test

test.describe("Vector<int> (v1.8 Grupo C, Phase 1)", () -> {
    test.it("push then get/len", () -> {
        var v := Vector<int>()
        v.push(10)
        v.push(20)
        v.push(30)
        test.expect(v.len()).toBe(3)
        test.expect(v.get(0)).toBe(10)
        test.expect(v.get(2)).toBe(30)
    })

    test.it("grows past initial capacity (2x growth)", () -> {
        var v := Vector<int>()
        var i := 0
        while i < 20 {
            v.push(i * i)
            i := i + 1
        }
        test.expect(v.len()).toBe(20)
        test.expect(v.get(19)).toBe(361)
        test.expect(v.get(10)).toBe(100)
    })
})

test.describe("Vector<int> set/pop/is_empty/clear (v1.8 Grupo C, Phase 2)", () -> {
    test.it("set overwrites in place", () -> {
        var v := Vector<int>()
        v.push(10)
        v.push(20)
        v.set(1, 99)
        test.expect(v.get(1)).toBe(99)
        test.expect(v.len()).toBe(2)
    })

    test.it("pop returns last element and shrinks", () -> {
        var v := Vector<int>()
        v.push(1)
        v.push(2)
        var x := v.pop()
        test.expect(x ?: -1).toBe(2)
        test.expect(v.len()).toBe(1)
    })

    test.it("pop on empty returns nil", () -> {
        var v := Vector<int>()
        var y := v.pop()
        test.expect(y == nil).toBeTruthy()
    })

    test.it("is_empty reflects contents", () -> {
        var v := Vector<int>()
        test.expect(v.is_empty()).toBe(1)
        v.push(5)
        test.expect(v.is_empty()).toBe(0)
    })

    test.it("clear empties but keeps the vector reusable", () -> {
        var v := Vector<int>()
        v.push(1)
        v.push(2)
        v.push(3)
        v.clear()
        test.expect(v.is_empty()).toBe(1)
        v.push(42)
        test.expect(v.get(0)).toBe(42)
        test.expect(v.len()).toBe(1)
    })
})

test.describe("Vector<float> (v1.8 Grupo C, Phase 3)", () -> {
    test.it("push/get/set with float values", () -> {
        var v := Vector<float>()
        v.push(1.5)
        v.push(2.5)
        v.push(3.5)
        test.expect(v.get(0)).toBeCloseTo(1.5)
        test.expect(v.get(2)).toBeCloseTo(3.5)
        v.set(1, 9.5)
        test.expect(v.get(1)).toBeCloseTo(9.5)
        test.expect(v.len()).toBe(3)
    })

    test.it("pop returns float? and empties to nil", () -> {
        var v := Vector<float>()
        v.push(1.5)
        v.push(2.5)
        var x := v.pop()
        test.expect(x ?: 0.0).toBeCloseTo(2.5)
        test.expect(v.len()).toBe(1)
        var drop := v.pop()
        var y := v.pop()
        test.expect(y == nil).toBeTruthy()
    })

    test.it("grows past initial capacity", () -> {
        var v := Vector<float>()
        var i := 0
        while i < 12 {
            v.push(i * 1.0)
            i := i + 1
        }
        test.expect(v.len()).toBe(12)
        test.expect(v.get(11)).toBeCloseTo(11.0)
    })
})

test.describe("Vector<string> (v1.8 Grupo C, Phase 4)", () -> {
    test.it("push/get/set with element ARC", () -> {
        var v := Vector<string>()
        v.push("a")
        v.push("b")
        test.expect(v.get(0)).toBe("a")
        v.set(0, "z")
        test.expect(v.get(0)).toBe("z")
        test.expect(v.len()).toBe(2)
    })

    test.it("get returns an owned value that survives clear", () -> {
        var v := Vector<string>()
        v.push("keep")
        var a := v.get(0)
        v.clear()
        test.expect(a).toBe("keep")
    })

    test.it("pop returns string? consumed via Elvis over an owned temp", () -> {
        var v := Vector<string>()
        v.push("x")
        v.push("y")
        test.expect(v.pop() ?: "none").toBe("y")
        test.expect(v.pop() ?: "none").toBe("x")
        test.expect(v.pop() ?: "none").toBe("none")
    })

    test.it("element co-ownership survives clear", () -> {
        var s := "shared"
        var v := Vector<string>()
        v.push(s)
        v.push(s)
        v.clear()
        test.expect(s).toBe("shared")
    })
})

test.describe("Vector<T>.to_array() (v1.8 Grupo C, Phase 5)", () -> {
    test.it("Vector<int>.to_array() returns a matching IntMatrix", () -> {
        var v := Vector<int>()
        v.push(10)
        v.push(20)
        var arr := v.to_array()
        test.expect(arr[0]).toBe(10)
        test.expect(arr[1]).toBe(20)
        test.expect(arr).toHaveLength(2)
    })

    test.it("Vector<float>.to_array() returns a matching Matrix", () -> {
        var v := Vector<float>()
        v.push(1.5)
        v.push(2.5)
        var arr := v.to_array()
        test.expect(arr[0]).toBeCloseTo(1.5)
        test.expect(arr[1]).toBeCloseTo(2.5)
    })

    test.it("Vector<string>.to_array() returns a matching StringMatrix that survives clear()", () -> {
        var v := Vector<string>()
        v.push("a")
        v.push("b")
        var arr := v.to_array()
        v.clear()
        test.expect(arr[0]).toBe("a")
        test.expect(arr[1]).toBe("b")
    })
})

test.describe("Vector<T> for-in iteration (v1.8 Grupo C, Phase 5)", () -> {
    test.it("iterates Vector<int> in order", () -> {
        var v := Vector<int>()
        v.push(1)
        v.push(2)
        v.push(3)
        var sum := 0
        for x in v {
            sum += x
        }
        test.expect(sum).toBe(6)
    })

    test.it("iterates Vector<string> in order", () -> {
        var v := Vector<string>()
        v.push("a")
        v.push("b")
        var result := ""
        for x in v {
            result += x
        }
        test.expect(result).toBe("ab")
    })

    test.it("element survives v.clear() called inside the loop body", () -> {
        var v := Vector<string>()
        v.push("a")
        var seen := "unset"
        for x in v {
            v.clear()
            seen := x
        }
        test.expect(seen).toBe("a")
    })

    test.it("loop bound reloads each iteration, doesn't abort when 2+ elements shrink", () -> {
        var v := Vector<string>()
        v.push("a")
        v.push("b")
        var count := 0
        var seen := "unset"
        for x in v {
            v.clear()
            seen := x
            count += 1
        }
        test.expect(count).toBe(1)
        test.expect(seen).toBe("a")
    })
})

test.describe("Stack<T> (v1.8 Grupo D)", () -> {
    test.it("push/pop is LIFO, size and is_empty track state", () -> {
        var s := Stack<int>()
        s.push(1)
        s.push(2)
        s.push(3)
        test.expect(s.size()).toBe(3)
        test.expect(s.is_empty()).toBe(0)
        test.expect(s.pop() ?: -1).toBe(3)
        test.expect(s.pop() ?: -1).toBe(2)
        test.expect(s.size()).toBe(1)
    })

    test.it("peek() returns an owned value that survives subsequent pop()s", () -> {
        var s := Stack<string>()
        s.push("a")
        var top := s.peek()
        test.expect(top).toBe("a")
        test.expect(s.pop() ?: "none").toBe("a")
        test.expect(s.pop() ?: "none").toBe("none")
    })
})

test.describe("Queue<T> (v1.8 Grupo D)", () -> {
    test.it("enqueue/dequeue is FIFO, size and is_empty track state", () -> {
        var q := Queue<int>()
        q.enqueue(1)
        q.enqueue(2)
        q.enqueue(3)
        test.expect(q.size()).toBe(3)
        test.expect(q.is_empty()).toBe(0)
        test.expect(q.dequeue() ?: -1).toBe(1)
        test.expect(q.dequeue() ?: -1).toBe(2)
        test.expect(q.size()).toBe(1)
    })

    test.it("front() returns an owned value without removing it", () -> {
        var q := Queue<string>()
        q.enqueue("a")
        q.enqueue("b")
        test.expect(q.front()).toBe("a")
        test.expect(q.size()).toBe(2)
        test.expect(q.dequeue() ?: "none").toBe("a")
    })

    test.it("dequeue() past exhaustion falls back via ?:", () -> {
        var q := Queue<string>()
        q.enqueue("a")
        test.expect(q.dequeue() ?: "none").toBe("a")
        test.expect(q.dequeue() ?: "none").toBe("none")
    })

    test.it("ring buffer wraparound + growth relinearizes logical order", () -> {
        var q := Queue<int>()
        q.enqueue(0)
        q.enqueue(1)
        q.enqueue(2)
        q.enqueue(3)
        test.expect(q.dequeue() ?: -1).toBe(0)
        test.expect(q.dequeue() ?: -1).toBe(1)
        q.enqueue(4)
        q.enqueue(5)
        q.enqueue(6)
        test.expect(q.dequeue() ?: -1).toBe(2)
        test.expect(q.dequeue() ?: -1).toBe(3)
        test.expect(q.dequeue() ?: -1).toBe(4)
        test.expect(q.dequeue() ?: -1).toBe(5)
        test.expect(q.dequeue() ?: -1).toBe(6)
    })
})
