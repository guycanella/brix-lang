import math
import test

test.describe("Physical constants (v1.8 Grupo A)", () -> {
    test.it("speed of light c_light", () -> {
        test.expect(math.c_light).toBeCloseTo(299792458.0)
    })

    test.it("standard gravity g_earth", () -> {
        test.expect(math.g_earth).toBeCloseTo(9.80665)
    })

    test.it("Avogadro number magnitude", () -> {
        test.expect(math.avogadro).toBeGreaterThan(6.0e23)
    })

    test.it("ideal gas constant R_gas", () -> {
        test.expect(math.R_gas).toBeCloseTo(8.314462618)
    })
})

test.describe("LU decomposition (v1.8 Grupo B)", () -> {
    test.it("L has unit diagonal", () -> {
        var A := zeros(2, 2)
        A[0][0] := 0.0
        A[0][1] := 2.0
        A[1][0] := 1.0
        A[1][1] := 0.0
        var { L, U, P } := math.lu(A)
        test.expect(L[0][0]).toBeCloseTo(1.0)
        test.expect(L[1][1]).toBeCloseTo(1.0)
    })

    test.it("U is upper-triangular with expected values", () -> {
        var A := zeros(2, 2)
        A[0][0] := 0.0
        A[0][1] := 2.0
        A[1][0] := 1.0
        A[1][1] := 0.0
        var { L, U, P } := math.lu(A)
        test.expect(U[0][0]).toBeCloseTo(1.0)
        test.expect(U[1][1]).toBeCloseTo(2.0)
    })

    test.it("P is a 0-based permutation vector", () -> {
        var A := zeros(2, 2)
        A[0][0] := 0.0
        A[0][1] := 2.0
        A[1][0] := 1.0
        A[1][1] := 0.0
        var { L, U, P } := math.lu(A)
        test.expect(P[0]).toBe(1)
        test.expect(P[1]).toBe(0)
    })

    test.it("3x3 with two pivots recovers non-trivial factors", () -> {
        var A := zeros(3, 3)
        A[0][0] := 2.0
        A[0][1] := 1.0
        A[0][2] := 1.0
        A[1][0] := 4.0
        A[1][1] := 3.0
        A[1][2] := 3.0
        A[2][0] := 8.0
        A[2][1] := 7.0
        A[2][2] := 9.0
        var { L, U, P } := math.lu(A)
        test.expect(P[0]).toBe(2)
        test.expect(P[1]).toBe(0)
        test.expect(P[2]).toBe(1)
        test.expect(U[0][0]).toBeCloseTo(8.0)
        test.expect(L[1][0]).toBeCloseTo(0.25)
        test.expect(L[2][1]).toBeCloseTo(0.666667)
        test.expect(U[2][2]).toBeCloseTo(-0.666667)
    })

    test.it("singular matrix still factors (zero pivot, no crash)", () -> {
        var A := zeros(2, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 2.0
        A[1][1] := 4.0
        var { L, U, P } := math.lu(A)
        test.expect(L[0][0]).toBeCloseTo(1.0)
        test.expect(U[1][1]).toBeCloseTo(0.0)
    })
})

test.describe("QR decomposition (v1.8 Grupo B)", () -> {
    test.it("R is upper-triangular", () -> {
        var A := zeros(2, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 3.0
        A[1][1] := 4.0
        var { Q, R } := math.qr(A)
        test.expect(R[1][0]).toBeCloseTo(0.0)
    })

    test.it("Q has orthonormal columns", () -> {
        var A := zeros(2, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 3.0
        A[1][1] := 4.0
        var { Q, R } := math.qr(A)
        test.expect(Q[0][0] * Q[0][0] + Q[1][0] * Q[1][0]).toBeCloseTo(1.0)
    })

    test.it("Q*R reconstructs A", () -> {
        var A := zeros(2, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 3.0
        A[1][1] := 4.0
        var { Q, R } := math.qr(A)
        test.expect(Q[0][0] * R[0][0] + Q[0][1] * R[1][0]).toBeCloseTo(1.0)
        test.expect(Q[1][0] * R[0][1] + Q[1][1] * R[1][1]).toBeCloseTo(4.0)
    })

    test.it("rectangular tall QR preserves full shapes and reconstructs A", () -> {
        var A := zeros(3, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 3.0
        A[1][1] := 4.0
        A[2][0] := 5.0
        A[2][1] := 6.0
        var { Q, R } := math.qr(A)
        test.expect(Q.rows).toBe(3)
        test.expect(Q.cols).toBe(3)
        test.expect(R.rows).toBe(3)
        test.expect(R.cols).toBe(2)
        test.expect(R[2][0]).toBeCloseTo(0.0)
        test.expect(R[2][1]).toBeCloseTo(0.0)
        test.expect(Q[0][0] * R[0][0] + Q[0][1] * R[1][0] + Q[0][2] * R[2][0]).toBeCloseTo(1.0)
        test.expect(Q[2][0] * R[0][1] + Q[2][1] * R[1][1] + Q[2][2] * R[2][1]).toBeCloseTo(6.0)
    })
})

test.describe("SVD (v1.8 Grupo B)", () -> {
    test.it("singular values of [[1,2],[3,4]]", () -> {
        var A := zeros(2, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 3.0
        A[1][1] := 4.0
        var { U, S, Vt } := math.svd(A)
        test.expect(S[0]).toBeCloseTo(5.464986)
        test.expect(S[1]).toBeCloseTo(0.365966)
    })

    test.it("U*diag(S)*Vt reconstructs A", () -> {
        var A := zeros(2, 2)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[1][0] := 3.0
        A[1][1] := 4.0
        var { U, S, Vt } := math.svd(A)
        test.expect(U[0][0] * S[0] * Vt[0][0] + U[0][1] * S[1] * Vt[1][0]).toBeCloseTo(1.0)
        test.expect(U[1][0] * S[0] * Vt[0][1] + U[1][1] * S[1] * Vt[1][1]).toBeCloseTo(4.0)
    })

    test.it("rectangular wide SVD preserves full shapes and reconstructs A", () -> {
        var A := zeros(2, 3)
        A[0][0] := 1.0
        A[0][1] := 2.0
        A[0][2] := 3.0
        A[1][0] := 4.0
        A[1][1] := 5.0
        A[1][2] := 6.0
        var { U, S, Vt } := math.svd(A)
        test.expect(U.rows).toBe(2)
        test.expect(U.cols).toBe(2)
        test.expect(S.rows).toBe(2)
        test.expect(S.cols).toBe(1)
        test.expect(Vt.rows).toBe(3)
        test.expect(Vt.cols).toBe(3)
        test.expect(U[0][0] * S[0] * Vt[0][0] + U[0][1] * S[1] * Vt[1][0]).toBeCloseTo(1.0)
        test.expect(U[0][0] * S[0] * Vt[0][2] + U[0][1] * S[1] * Vt[1][2]).toBeCloseTo(3.0)
        test.expect(U[1][0] * S[0] * Vt[0][1] + U[1][1] * S[1] * Vt[1][1]).toBeCloseTo(5.0)
        test.expect(U[1][0] * S[0] * Vt[0][2] + U[1][1] * S[1] * Vt[1][2]).toBeCloseTo(6.0)
    })
})

test.describe("Cholesky / solve / norm (v1.8 Grupo B)", () -> {
    test.it("cholesky of [[4,2],[2,3]]", () -> {
        var A := zeros(2, 2)
        A[0][0] := 4.0
        A[0][1] := 2.0
        A[1][0] := 2.0
        A[1][1] := 3.0
        var L := math.cholesky(A)
        test.expect(L[0][0]).toBeCloseTo(2.0)
        test.expect(L[1][0]).toBeCloseTo(1.0)
        test.expect(L[1][1]).toBeCloseTo(1.414214)
        test.expect(L[0][1]).toBeCloseTo(0.0)
    })

    test.it("solve A*x = b (row-vector RHS)", () -> {
        var A := zeros(2, 2)
        A[0][0] := 2.0
        A[1][1] := 3.0
        var b := [4.0, 9.0]
        var x := math.solve(A, b)
        test.expect(x[0]).toBeCloseTo(2.0)
        test.expect(x[1]).toBeCloseTo(3.0)
    })

    test.it("solve with multiple RHS (n x nrhs)", () -> {
        var A := zeros(2, 2)
        A[0][0] := 2.0
        A[1][1] := 3.0
        var b := zeros(2, 2)
        b[0][0] := 4.0
        b[0][1] := 2.0
        b[1][0] := 9.0
        b[1][1] := 6.0
        var x := math.solve(A, b)
        test.expect(x[0][0]).toBeCloseTo(2.0)
        test.expect(x[0][1]).toBeCloseTo(1.0)
        test.expect(x[1][0]).toBeCloseTo(3.0)
        test.expect(x[1][1]).toBeCloseTo(2.0)
    })

    test.it("vector L2 norm", () -> {
        var v := [3.0, 4.0]
        test.expect(math.norm(v)).toBeCloseTo(5.0)
    })

    test.it("matrix norms (Frobenius / 1 / inf)", () -> {
        var M := zeros(2, 2)
        M[0][0] := 1.0
        M[0][1] := 2.0
        M[1][0] := 3.0
        M[1][1] := 4.0
        test.expect(math.norm_mat(M)).toBeCloseTo(5.477226)
        test.expect(math.norm_mat(M, 1)).toBeCloseTo(6.0)
        test.expect(math.norm_mat(M, 2)).toBeCloseTo(7.0)
    })
})
