import test

test.describe("Array methods (v1.7 Group B)", () -> {
    test.it("sort() returns elements in ascending order", () -> {
        var nums := [3, 1, 4, 1, 5, 9, 2, 6]
        var sorted := nums.sort()
        test.expect(sorted).toEqual([1, 1, 2, 3, 4, 5, 6, 9])

        var fnums := [3.5, 1.2, 9.9]
        var fsorted := fnums.sort()
        test.expect(fsorted[0]).toBeCloseTo(1.2)
        test.expect(fsorted[2]).toBeCloseTo(9.9)
    })

    test.it("sort_desc() returns elements in descending order", () -> {
        var nums := [3, 1, 4, 1, 5, 9, 2, 6]
        var desc := nums.sort_desc()
        test.expect(desc).toEqual([9, 6, 5, 4, 3, 2, 1, 1])
    })

    test.it("min() returns the smallest element", () -> {
        var nums := [3, 1, 4, 1, 5, 9, 2, 6]
        test.expect(nums.min()).toBe(1)

        var fnums := [3.5, 1.2, 9.9]
        test.expect(fnums.min()).toBeCloseTo(1.2)
    })

    test.it("max() returns the largest element", () -> {
        var nums := [3, 1, 4, 1, 5, 9, 2, 6]
        test.expect(nums.max()).toBe(9)

        var fnums := [3.5, 1.2, 9.9]
        test.expect(fnums.max()).toBeCloseTo(9.9)
    })

    test.it("flatten() collapses a 2D matrix into a 1D row", () -> {
        var m := ones(2, 3)
        var flat := m.flatten()
        test.expect(flat.rows).toBe(1)
        test.expect(flat.cols).toBe(6)
    })

    test.it("unique() preserves order of first appearance", () -> {
        var nums := [3, 1, 4, 1, 5, 9, 2, 6, 3, 5]
        var uniq := nums.unique()
        test.expect(uniq).toEqual([3, 1, 4, 5, 9, 2, 6])
    })

    test.it("reverse() reverses element order", () -> {
        var nums := [1, 2, 3, 4, 5]
        var rev := nums.reverse()
        test.expect(rev).toEqual([5, 4, 3, 2, 1])
    })

    test.it("append() adds a new element at the end without mutating the original", () -> {
        var nums := [1, 2, 3]
        var extended := nums.append(99)
        test.expect(extended).toEqual([1, 2, 3, 99])
        test.expect(nums).toEqual([1, 2, 3])
    })

    test.it("prepend() adds a new element at the start without mutating the original", () -> {
        var nums := [1, 2, 3]
        var prepended := nums.prepend(0)
        test.expect(prepended).toEqual([0, 1, 2, 3])
        test.expect(nums).toEqual([1, 2, 3])
    })

    test.it("count() returns the total number of elements", () -> {
        var nums := [1, 2, 3, 4]
        test.expect(nums.count()).toBe(4)

        var m := ones(2, 3)
        test.expect(m.count()).toBe(6)
    })
})

test.describe("Array slicing + negative index (v1.7 Group C)", () -> {
    test.it("slices with an inclusive range (nums[1..3])", () -> {
        var nums := [10, 20, 30, 40, 50]
        var sub := nums[1..3]
        test.expect(sub).toEqual([20, 30, 40])

        var fnums := [1.5, 2.5, 3.5, 4.5]
        var fsub := fnums[1..3]
        test.expect(fsub.cols).toBe(3)
        test.expect(fsub[0]).toBeCloseTo(2.5)
        test.expect(fsub[2]).toBeCloseTo(4.5)
    })

    test.it("slices with an exclusive range (nums[1..<4])", () -> {
        var nums := [10, 20, 30, 40, 50]
        var sub := nums[1..<4]
        test.expect(sub).toEqual([20, 30, 40])

        var fnums := [1.5, 2.5, 3.5, 4.5]
        var fsub := fnums[1..<3]
        test.expect(fsub).toHaveLength(2)
        test.expect(fsub[1]).toBeCloseTo(3.5)
    })

    test.it("supports negative indices, including from an expression", () -> {
        var nums := [10, 20, 30, 40, 50]
        test.expect(nums[-1]).toBe(50)
        test.expect(nums[-2]).toBe(40)

        var i := 0
        test.expect(nums[i - 1]).toBe(50)
    })

    test.it("allows assignment through a negative index", () -> {
        var nums := [10, 20, 30, 40, 50]
        nums[-1] := 99
        test.expect(nums[4]).toBe(99)
        test.expect(nums[-1]).toBe(99)

        var fnums := [1.5, 2.5, 3.5]
        fnums[-1] := 9.9
        test.expect(fnums[2]).toBeCloseTo(9.9)
    })
})
