import test

test.describe("Literal patterns", () -> {
    test.it("matches int literal", () -> {
        var x := 2
        var result := match x {
            1 -> "one"
            2 -> "two"
            3 -> "three"
            _ -> "other"
        }
        test.expect(result).toBe("two")
    })

    test.it("falls through to wildcard", () -> {
        var x := 99
        var result := match x {
            1 -> "one"
            2 -> "two"
            _ -> "other"
        }
        test.expect(result).toBe("other")
    })
})

test.describe("Binding patterns", () -> {
    test.it("binds value to variable", () -> {
        var x := 42
        var result := match x {
            n -> n * 2
        }
        test.expect(result).toBe(84)
    })
})

test.describe("Or-patterns", () -> {
    test.it("matches any of the listed values", () -> {
        var day := 6
        var result := match day {
            1 | 2 | 3 | 4 | 5 -> "weekday"
            6 | 7 -> "weekend"
            _ -> "invalid"
        }
        test.expect(result).toBe("weekend")
    })

    test.it("first arm wins", () -> {
        var x := 3
        var result := match x {
            1 | 2 | 3 -> "low"
            3 | 4 | 5 -> "mid"
            _ -> "high"
        }
        test.expect(result).toBe("low")
    })
})

test.describe("Guards", () -> {
    test.it("guard filters match arm", () -> {
        var x := 15
        var result := match x {
            n if n > 10 -> "big"
            n if n > 0  -> "small"
            _ -> "zero or negative"
        }
        test.expect(result).toBe("big")
    })

    test.it("guard with equality", () -> {
        var x := 7
        var result := match x {
            n if n % 2 == 0 -> "even"
            _ -> "odd"
        }
        test.expect(result).toBe("odd")
    })
})

test.describe("typeof in match", () -> {
    test.it("matches int type", () -> {
        var x := 42
        var result := match typeof(x) {
            "int" -> 1
            "float" -> 2
            "string" -> 3
            _ -> 0
        }
        test.expect(result).toBe(1)
    })

    test.it("matches float type", () -> {
        var x := 3.14
        var result := match typeof(x) {
            "int" -> 1
            "float" -> 2
            _ -> 0
        }
        test.expect(result).toBe(2)
    })
})

test.describe("Type coercion across arms", () -> {
    test.it("int arm and float arm coerce result to float", () -> {
        var x := 1
        var result := match x {
            1 -> 10
            2 -> 2
            _ -> 0
        }
        test.expect(result).toBe(10)
    })
})

test.describe("Destructuring patterns", () -> {
    test.it("binds all fields", () -> {
        struct Pt { x: int, y: int }
        var p := Pt { x: 3, y: 4 }
        var result := match p {
            { x, y } -> x + y
        }
        test.expect(result).toBe(7)
    })

    test.it("constrains with literal", () -> {
        struct Pt2 { x: int, y: int }
        var p := Pt2 { x: 5, y: 0 }
        var result := match p {
            { x, 0 } -> x
            { x, y } -> x + y
        }
        test.expect(result).toBe(5)
    })

    test.it("wildcard ignores field", () -> {
        struct Pt3 { x: int, y: int }
        var p := Pt3 { x: 99, y: 7 }
        var result := match p {
            { _, y } -> y
        }
        test.expect(result).toBe(7)
    })

    test.it("nested destructure returns correct value", () -> {
        struct Pt4 { x: int, y: int }
        var p := Pt4 { x: 10, y: 20 }
        var result := match p {
            { x, y } -> x + y
        }
        test.expect(result).toBe(30)
    })
})

test.describe("Range patterns", () -> {
    test.it("inclusive int range matches inside", () -> {
        var age := 30
        var result := match age {
            0..17 -> "minor"
            18..64 -> "adult"
            65..99 -> "senior"
            _ -> "other"
        }
        test.expect(result).toBe("adult")
    })

    test.it("exclusive int range excludes boundary", () -> {
        var x := 10
        var result := match x {
            0..<10 -> "below"
            10..20 -> "in"
            _ -> "above"
        }
        test.expect(result).toBe("in")
    })

    test.it("float range works", () -> {
        var score := 0.75
        var result := match score {
            0.0..<0.5 -> "fail"
            0.5..1.0 -> "pass"
            _ -> "invalid"
        }
        test.expect(result).toBe("pass")
    })
})
